{
  "name": "assistant-medical-personnel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Assistant médical personnel — PWA accompagnement santé chroniques (diabète T2, HTA, asthme)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "pnpm --filter web e2e",
    "e2e:install": "pnpm --filter web exec playwright install --with-deps chromium",
    "rules:check": "firebase emulators:exec --only firestore,storage --project demo-project \"node scripts/validate-rules.mjs\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "firebase-tools": "^13.29.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
